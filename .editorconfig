root = true

########################################
# Global
########################################
[*]
end_of_line = crlf
charset = utf-8
insert_final_newline = true
trim_trailing_whitespace = true

########################################
# C# / Razor / Cake
########################################
[*.{cs,csx,cake,cshtml}]
indent_style = space
indent_size = 4
tab_width = 4

# Keep existing using layout stable (repo often has Microsoft.* before System.*)
dotnet_sort_system_directives_first = false
dotnet_separate_import_directive_groups = false

# File-scoped namespaces.
csharp_style_namespace_declarations = file_scoped:suggestion

# Prefer scoped using declarations.
csharp_prefer_simple_using_statement = true:suggestion

# Prefer discards for unused values.
dotnet_style_unused_value_assignment = discard_variable:error
dotnet_style_unused_value_expression_statement = discard_variable:error

# Prefer var where it reads well (don't force everywhere).
csharp_style_var_for_built_in_types = true:suggestion
csharp_style_var_when_type_is_apparent = true:suggestion
csharp_style_var_elsewhere = true:suggestion

# Always use braces for control blocks.
csharp_prefer_braces = true:suggestion

# Prefer block-bodied properties/accessors (but allow expression-bodied when single-line).
csharp_style_expression_bodied_properties = when_on_single_line:suggestion
csharp_style_expression_bodied_accessors = when_on_single_line:suggestion

# Braces and newlines: match Allman style used throughout
csharp_new_line_before_open_brace = all
csharp_new_line_before_else = true
csharp_new_line_before_catch = true
csharp_new_line_before_finally = true
csharp_new_line_before_members_in_object_initializers = true
csharp_new_line_before_members_in_anonymous_types = true
csharp_new_line_between_query_expression_clauses = true

# Indentation
csharp_indent_case_contents = true
csharp_indent_switch_labels = true
csharp_indent_labels = one_less_than_current

# Spacing
csharp_space_after_keywords_in_control_flow_statements = true
csharp_space_before_open_square_brackets = false
csharp_space_between_method_call_parameter_list_parentheses = false
csharp_space_between_method_declaration_parameter_list_parentheses = false
csharp_space_between_parentheses = false
csharp_space_around_binary_operators = before_and_after
csharp_space_after_cast = false

# Prefer global usings when appropriate.
dotnet_prefer_global_using_directives = true:suggestion

########################################
# C# / .NET (additional repo-aligned preferences)
########################################
[*.{cs,csx}]
csharp_style_prefer_top_level_statements = false:suggestion
csharp_style_expression_bodied_methods = false:suggestion
csharp_style_expression_bodied_constructors = false:suggestion

dotnet_style_require_accessibility_modifiers = always:suggestion

dotnet_style_qualification_for_field = false:suggestion
dotnet_style_qualification_for_property = false:suggestion
dotnet_style_qualification_for_method = false:suggestion
dotnet_style_qualification_for_event = false:suggestion

csharp_style_conditional_delegate_call = true:suggestion

csharp_style_pattern_matching_over_is_with_cast_check = true:suggestion
csharp_style_pattern_matching_over_as_with_null_check = true:suggestion
csharp_style_inlined_variable_declaration = true:suggestion

dotnet_style_prefer_regions = true:silent

########################################
# Code style severities
########################################
dotnet_analyzer_diagnostic.severity = default

########################################
# XML / project files
########################################
[*.{xml,config,csproj,vbproj,fsproj,props,targets,tasks,proj,ilproj,nuspec,nuget,xdt,ruleset,resx,resw,xsd,xsl,xslt,wsdl,manifest,appxmanifest,appmanifest,natvis,vsixmanifest}]
indent_style = space
indent_size = 2
tab_width = 2

########################################
# XAML / WPF/MAUI
########################################
[*.xaml]
indent_style = space
indent_size = 4
tab_width = 4

########################################
# Solution files
########################################
[*.sln]
indent_style = tab
tab_width = 4
end_of_line = crlf
insert_final_newline = true

########################################
# Legacy files -- Remove if unnecessary
########################################
[packages.config]
indent_style = space
indent_size = 2
tab_width = 2